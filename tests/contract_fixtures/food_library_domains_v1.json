{
  "contract": "food_library_domains_v1",
  "libraryDomains": [
    "MealTemplate",
    "Recipe",
    "Ingredient/Product",
    "ShoppingList"
  ],
  "domainContracts": {
    "MealTemplate": {
      "owner": "meal_template_library",
      "identityFields": [
        "templateId",
        "ownerUserId",
        "templateVersion"
      ],
      "ownedFields": [
        "displayName",
        "description",
        "mealTypeHint",
        "draftItems",
        "draftTotals",
        "nutritionSnapshot",
        "imageRef"
      ]
    },
    "Recipe": {
      "owner": "recipe_library",
      "identityFields": [
        "recipeId",
        "ownerUserId",
        "recipeVersion"
      ],
      "ownedFields": [
        "title",
        "description",
        "ingredients",
        "steps",
        "instructions",
        "servings",
        "yield",
        "prepTimeMin",
        "cookTimeMin",
        "nutritionSnapshot",
        "imageRef"
      ]
    },
    "Ingredient/Product": {
      "owner": "ingredient_product_library",
      "identityFields": [
        "ingredientProductId",
        "recordScope"
      ],
      "ownedFields": [
        "displayName",
        "kind",
        "lifecycleState",
        "ownerUserId",
        "brandName",
        "ingredientName",
        "packageName",
        "category",
        "barcodeIdentities",
        "externalSourceIds",
        "servingSizes",
        "nutritionPer100",
        "defaultServing",
        "sourceAttribution",
        "confidence",
        "profileFlags",
        "dietaryFlags",
        "allergenFlags",
        "createdAt",
        "updatedAt"
      ]
    },
    "ShoppingList": {
      "owner": "shopping_list_library",
      "identityFields": [
        "listId",
        "ownerUserId"
      ],
      "ownedFields": [
        "title",
        "items",
        "itemRefs",
        "checkedState",
        "sortOrder",
        "notes"
      ]
    }
  },
  "ingredientProductRecordContract": {
    "recordKinds": [
      "generic_ingredient",
      "branded_product"
    ],
    "recordScopes": [
      "global_seed",
      "global_internal",
      "user_scoped"
    ],
    "lifecycleStates": [
      "candidate",
      "verified",
      "rejected"
    ],
    "verifiedMeaning": "verified_for_fitaly_catalog_use_not_medical_or_dietary_safety_claim",
    "requiredFields": [
      "ingredientProductId",
      "recordScope",
      "lifecycleState",
      "kind",
      "displayName",
      "sourceAttribution",
      "confidence",
      "nutritionPer100",
      "defaultServing",
      "servingSizes",
      "profileFlags",
      "createdAt",
      "updatedAt"
    ],
    "optionalFields": [
      "ownerUserId",
      "brandName",
      "ingredientName",
      "packageName",
      "category",
      "barcodeIdentities",
      "externalSourceIds",
      "dietaryFlags",
      "allergenFlags"
    ],
    "kindSpecificRequiredFields": {
      "generic_ingredient": [
        "ingredientName"
      ],
      "branded_product": [
        "brandName"
      ]
    },
    "ownership": {
      "scopeField": "recordScope",
      "ownerField": "ownerUserId",
      "userScopedScope": "user_scoped",
      "userScopedRequiresOwnerUserId": true,
      "globalScopesMustNotUseOwnerUserId": [
        "global_seed",
        "global_internal"
      ],
      "globalRecordsAreUserAccountData": false
    },
    "sourceAttribution": {
      "requiredFields": [
        "sourceType",
        "sourceId",
        "sourceName"
      ],
      "optionalFields": [
        "provider",
        "license",
        "observedAt",
        "reviewedAt",
        "reviewedBy"
      ],
      "sourceTypes": [
        "internal_seed",
        "internal_review",
        "user_created",
        "external_provider",
        "barcode_identity",
        "runtime_ai_candidate"
      ],
      "candidateOnlySourceTypes": [
        "barcode_identity",
        "runtime_ai_candidate"
      ],
      "durableTruthRequiresNonAiSource": true
    },
    "confidence": {
      "requiredFields": [
        "identity",
        "nutrition",
        "profile"
      ],
      "levels": [
        "unknown",
        "low",
        "medium",
        "high",
        "verified"
      ],
      "unknownMeansNotSafeToAssume": true
    },
    "nutritionPer100": {
      "requiredFields": [
        "basis",
        "unit",
        "kcal",
        "protein",
        "fat",
        "carbs"
      ],
      "optionalFields": [
        "fiber",
        "sugar",
        "salt",
        "saturatedFat"
      ],
      "allowedBases": [
        "per_100g",
        "per_100ml"
      ],
      "missingNutritionPolicy": "unknown_not_guessed",
      "runtimeAiMayBecomeDurableNutritionTruth": false
    },
    "serving": {
      "requiredFields": [
        "defaultServing",
        "servingSizes"
      ],
      "servingSizeFields": [
        "servingSizeId",
        "label",
        "quantity",
        "unit"
      ],
      "allowedUnits": [
        "g",
        "ml",
        "piece",
        "serving"
      ]
    },
    "profileFlags": {
      "requiredFields": [
        "dietaryFlags",
        "allergenFlags",
        "profileCompatibilityStatus"
      ],
      "allowedDietaryFlags": [
        "vegan",
        "vegetarian",
        "gluten_free",
        "lactose_free",
        "halal",
        "kosher"
      ],
      "allowedAllergenFlags": [
        "milk",
        "eggs",
        "fish",
        "shellfish",
        "tree_nuts",
        "peanuts",
        "wheat",
        "soy",
        "sesame"
      ],
      "compatibilityStatuses": [
        "unknown",
        "compatible",
        "incompatible",
        "warning"
      ],
      "missingProfilePolicy": "unknown_not_guessed",
      "verifiedIsMedicalOrDietarySafetyClaim": false,
      "runtimeAiMayBecomeDurableProfileTruth": false
    },
    "barcodeIdentities": {
      "minimalIdentityFields": [
        "barcode",
        "format",
        "sourceType"
      ],
      "optionalFields": [
        "normalizedBarcode",
        "country",
        "sourceId",
        "observedAt"
      ],
      "noCatalogWriteInThisSlice": true,
      "noTopLevelAddMealBarcodePath": true
    },
    "localCacheBoundary": {
      "representedAs": "projection_only",
      "localCacheIsTruth": false,
      "mayPromoteToGlobalWithoutReview": false
    }
  },
  "loggedMealBoundary": {
    "owner": "meal_logging",
    "schemaName": "Meal",
    "mustRemainNarrow": true,
    "mustNotServeAsLibraryCatchAll": true,
    "mustNotGainFields": [
      "mealTemplateId",
      "templateId",
      "templateVersion",
      "recipeId",
      "recipeInstructions",
      "recipeSteps",
      "recipeYield",
      "recipeServings",
      "productId",
      "productBarcode",
      "productCatalogId",
      "productLifecycleState",
      "shoppingListId",
      "shoppingListItems",
      "shoppingListCheckedAt",
      "shoppingListLifecycleState"
    ],
    "rationale": "Logged Meal is owned by meal logging as the persisted eaten-meal schema. It must remain narrow, must not serve as the food-library catch-all schema, and must not gain recipe, product, shopping-list, or template-specific fields."
  },
  "currentSavedMealsBoundary": {
    "currentNames": [
      "myMeals",
      "saved_meals"
    ],
    "isFinalLibraryFoundation": false,
    "laterTargetDomain": "MealTemplate",
    "compatibilityFallbackToOldShapeAccepted": false,
    "legacyMarkersNotCanonicalLibraryFoundation": [
      "myMeals",
      "saved_meals",
      "source:saved",
      "inputMethod:saved",
      "savedMealRefId"
    ],
    "mustNotExpandWith": [
      "mealTemplateId",
      "templateId",
      "templateVersion",
      "recipeId",
      "recipeInstructions",
      "recipeSteps",
      "recipeYield",
      "recipeServings",
      "productId",
      "productBarcode",
      "productCatalogId",
      "productLifecycleState",
      "shoppingListId",
      "shoppingListItems",
      "shoppingListCheckedAt",
      "shoppingListLifecycleState"
    ],
    "rationale": "Current myMeals and saved-meal shapes are not the final food-library foundation. Later CH-06 work targets MealTemplate ownership, and this contract rejects compatibility fallback to the old saved-meal shape as a release architecture."
  },
  "barcodeBoundary": {
    "resultOwnership": [
      "backend_provider_adapter",
      "add_meal_draft_source"
    ],
    "addMealDraftSourceOnly": true,
    "createsFirstPartyProductCatalogInThisSlice": false,
    "mustNotWriteLibraryDomains": [
      "Ingredient/Product"
    ],
    "rationale": "Barcode lookup results are owned only by the backend provider adapter and Add Meal draft source. This slice does not create a first-party product catalog or any permanent food-library product record."
  }
}
