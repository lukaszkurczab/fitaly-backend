# App
APP_NAME=Fitaly
DESCRIPTION=Backend API for Fitaly mobile application.
VERSION=0.1.0
DEBUG=true
API_V1_PREFIX=/api/v1
# environment: local/development/staging/production
ENVIRONMENT=development
# Gunicorn worker count. Railway prod launch-candidate uses 2; smoke uses 1.
WEB_CONCURRENCY=2

# OpenAI
# Required for backend-managed AI endpoints such as /api/v1/ai/ask and /api/v1/ai/photo/analyze.
OPENAI_API_KEY=

# Firebase / Firestore
# Allowed origins for CORS (comma-separated).
# Production must provide explicit origins and must not use '*'.
CORS_ORIGINS=http://localhost:19006,https://your-production-domain.com

# Google Cloud project ID for Firebase/Firestore.
FIREBASE_PROJECT_ID=

# Absolute path to the Firebase service account JSON key. Required for Firebase Admin initialization.
GOOGLE_APPLICATION_CREDENTIALS=

# Firebase Admin service account fields used by Firebase Admin.
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=
# Firestore database ID. Use "(default)" for production, "fitaly-smoke" for smoke.
FIRESTORE_DATABASE_ID=(default)
# Initialize Firestore during app startup. Prod uses true; smoke defaults to false
# and only sets true for infra readiness tests.
EAGER_FIREBASE_INIT=true

# DSN for Sentry. If empty, Sentry is disabled.
SENTRY_DSN=
# Sentry environment tag
SENTRY_ENVIRONMENT=development
# Sentry performance tracing sample rate. Prod launch-candidate uses 0.01; smoke uses 0.
SENTRY_TRACES_SAMPLE_RATE=0.01

# Product limits
AI_CREDITS_FREE=100
AI_CREDITS_PREMIUM=800
AI_CREDIT_COST_CHAT=1
AI_CREDIT_COST_TEXT_MEAL=1
AI_CREDIT_COST_PHOTO=5
AI_GATEWAY_ENABLED=true

# Telemetry — set to true to accept v2 batch events from mobile.
# Also requires mobile flag: EXPO_PUBLIC_ENABLE_TELEMETRY=true
# When enabled, the backend logs structured ingest summaries:
#   telemetry.ingest.ok            (INFO)    — batch accepted
#   telemetry.ingest.rejected      (WARNING) — disallowed event name
#   telemetry.ingest.rate_limited  (WARNING) — rate limit exceeded
#   telemetry.ingest.firestore_error (ERROR) — Firestore write failure
TELEMETRY_ENABLED=false

HABITS_ENABLED=true
STATE_ENABLED=true
SMART_REMINDERS_ENABLED=true
WEEKLY_REPORTS_ENABLED=true

AI_REJECT_COST=0.2
AI_LOCAL_COST=0.5
AI_GATEWAY_ML_ENABLED=false
AI_GATEWAY_ML_MODEL_PATH=models/ai_gateway_classifier.joblib
AI_GATEWAY_ML_THRESHOLD_OFF_TOPIC=0.35

# Billing integrations
REVENUECAT_WEBHOOK_SECRET=
REVENUECAT_API_KEY=

# Port injection for Railway (set automatically)
PORT=
